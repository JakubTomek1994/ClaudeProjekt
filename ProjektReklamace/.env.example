# Database (SQLite for dev — switch to PostgreSQL in prod)
DATABASE_URL="file:./prisma/dev.db"

# Auth.js
# Generate with: npx auth secret
AUTH_SECRET=""
# AUTH_URL — odkomentujte na produkci, v devu nech AUTH_TRUST_HOST
# AUTH_URL="https://reklamace.firma.cz"
AUTH_TRUST_HOST=true

# Cron — Bearer secret pro POST /api/cron/check-deadlines
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# Microsoft Graph (Fáze 2 — email integrace)
# Azure App Registration: tenant ID, client ID, client secret
MS_TENANT_ID=""
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
MS_MAILBOX_USER="reklamace@firma.cz"
MS_MAILBOX_REPLY_TO="reklamace@firma.cz"

# Push notifikace (Fáze 2)
# ntfy.sh — vlastní topic (zachovejte tajný)
NTFY_TOPIC=""
# Telegram (alternativa)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Aplikace
# Veřejné URL aplikace (pro generování linků v emailech)
APP_URL="http://localhost:3030"
