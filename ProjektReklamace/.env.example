# Database — Postgres (Neon recommended, https://neon.tech)
# Format: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=""

# Vercel Blob (storage pro PDF a uploady dokumentů)
# Token z Vercel dashboard → Storage → Blob → .env.local tab
BLOB_READ_WRITE_TOKEN=""

# Auth.js
# Generate with: npx auth secret
AUTH_SECRET=""
# AUTH_URL — odkomentujte na produkci, v devu nech AUTH_TRUST_HOST
# AUTH_URL="https://reklamace.firma.cz"
AUTH_TRUST_HOST=true

# Cron — Bearer secret pro POST /api/cron/check-deadlines
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# Microsoft Graph (Fáze 2 — email integrace)
# Azure App Registration: tenant ID, client ID, client secret
MS_TENANT_ID=""
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
MS_MAILBOX_USER="reklamace@firma.cz"
MS_MAILBOX_REPLY_TO="reklamace@firma.cz"

# Push notifikace (Fáze 2)
# ntfy.sh — vlastní topic (zachovejte tajný)
NTFY_TOPIC=""
# Telegram (alternativa)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Aplikace
# Veřejné URL aplikace (pro generování linků v emailech)
APP_URL="http://localhost:3030"
